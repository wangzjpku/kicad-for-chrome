# KiCad Web Editor Backend - 环境变量配置示例
# 复制此文件为 .env 并修改为你自己的配置

# ==========================================
# 应用配置
# ==========================================
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ==========================================
# 数据库配置 (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql+asyncpg://kicad:kicad@localhost:5432/kicad_web

# ==========================================
# Redis 配置
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# KiCad 配置
# ==========================================
# Windows 示例:
KICAD_CLI_PATH=E:\Program Files\KiCad\9.0\bin\kicad-cli.exe
KICAD_SHARE_PATH=E:\Program Files\KiCad\9.0\share\kicad

# Linux 示例:
# KICAD_CLI_PATH=/usr/bin/kicad-cli
# KICAD_SHARE_PATH=/usr/share/kicad

# 是否使用虚拟显示 (Linux Docker 环境)
USE_VIRTUAL_DISPLAY=false

# ==========================================
# 文件路径配置
# ==========================================
PROJECTS_DIR=./projects
OUTPUT_DIR=./output
TEMP_DIR=./temp

# ==========================================
# 安全配置
# ==========================================
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==========================================
# CORS 配置 (开发环境)
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
