    "通用设计模式": {
      "去耦电容": "100% - 每个电源引脚必须有100nF电容",
      "LED指示灯": "95% - 状态可见性很重要",
      "输入输出滤波": "100% - 电源必须滤波",
      "USB连接器": "70% - 现代标准接口",
      "LDO_DCDC稳压器": "85% - 稳压必不可少"
    },
    "AI设计常见缺陷": {
      "去耦不足": "80% - 只放大电容，缺少分布式100nF",
      "无输入保护": "70% - 缺少保险丝、TVS、防反接",
      "晶振电路错误": "60% - 电容值错误或缺失",
      "无USB串联电阻": "70% - 缺少22-49R电阻",
      "缺失复位电路": "40% - MCU必须要有复位"
    },
    "提取的设计规则": [
      "规则1: 电源去耦 - 每个IC电源引脚3mm内必须有100nF电容",
      "规则2: 输入保护 - 外部电源必须有保险丝、TVS、防反接",
      "规则3: 晶振电路 - 晶振必须有正确的负载电容(通常22pF)",
      "规则4: LED限流 - 3.3V下使用470-680R电阻",
      "规则5: 复位电路 - MCU必须有10k上拉+按钮复位",
      "规则6: USB接口 - D+/D-必须有22-49R串联电阻和ESD保护",
      "规则7: 电机保护 - 电机输出必须有续流二极管和电流检测",
      "规则8: 电池充电 - 锂电池必须有专用充电IC和保护电路"
    ]
  }
